#include <stdio.h>
#include <ctype.h>
#define SIZE 100

char stack[SIZE];
int top = -1;
void push(char x) {
    stack[++top] = x;
}

char pop() {
    return stack[top--];
}

// Priority function
int priority(char x) {
    if (x == '(') return 0;
    if (x == '+' || x == '-') return 1;
    if (x == '*' || x == '/') return 2;
    if (x == '^') return 3;
    return 0;
}

int main() {
    char infix[] = "A+B*(C^D-E)^(F+G*H)-I";
    char postfix[SIZE];
    int k = 0;

    for (int i = 0; infix[i] != '\0'; i++) {
        
        if (isalnum(infix[i])) {
            postfix[k++] = infix[i];
        }
        else if (infix[i] == '(') {
            push(infix[i]);
        }
        else if (infix[i] == ')') {
            while (stack[top] != '(') {
                postfix[k++] = pop();
            }
            pop(); 
        }
        else {
            while (priority(stack[top]) >= priority(infix[i])) {
                postfix[k++] = pop();
            }
            push(infix[i]);
        }
    }
    while (top != -1) {
        postfix[k++] = pop();
    }
    postfix[k] = '\0';
    printf("Postfix Expression: %s\n", postfix);
    return 0;
}

